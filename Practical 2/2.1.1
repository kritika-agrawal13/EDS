# Initialize empty list
numbers = []

while True:
    # Display menu
    print("1. Add")
    print("2. Remove")
    print("3. Display")
    print("4. Quit")
    
    choice = input("Enter choice: ").strip()
    
    if choice == '1':  # Add
        value = input("Integer: ").strip()
        try:
            num = int(value)
            numbers.append(num)
            print(f"List after adding: {numbers}")
        except ValueError:
            print("Invalid input")
    
    elif choice == '2':  # Remove
        if not numbers:
            print("List is empty")
        else:
            value = input("Integer: ").strip()
            try:
                num = int(value)
                if num in numbers:
                    numbers.remove(num)
                    print(f"List after removing: {numbers}")
                else:
                    print("Element not found")
            except ValueError:
                print("Invalid input")
    
    elif choice == '3':  # Display
        if not numbers:
            print("List is empty")
        else:
            print(numbers)
    
    elif choice == '4':  # Quit
        break
    
    else:
        print("Invalid choice")
